# Environment Variables for 5G Network Slicing
# Copy this file to .env and update values

# Database Configuration (mysql.connector — MS1/MS2/MS3/MS5, congestion_engine, models, init_db)
DB_HOST=mysql
DB_PORT=3306
DB_USER=network_user
DB_PASSWORD=network_pass
DB_NAME=network_slicing_5g

# MS1 → MS3 sync (app.py): set MS3_URL; disable with DISABLE_MS3_SYNC
MS3_URL=http://ms3:5000
# DISABLE_MS3_SYNC=true

# MS1 public URL prefix when behind nginx (app.py MS1_PUBLIC_PREFIX)
# MS1_PUBLIC_PREFIX=

# Congestion engine (congestion_engine.py)
# CONGESTION_JITTER_REF_MS=5.0
# Bands JSON: CONGESTION_THRESHOLDS_JSON={"my_slice":{"pressure_low_max":30,"pressure_medium_max":60}}
# SLA refs JSON: CONGESTION_SLA_REFS_JSON={"3":{"delay_ref_ms":10,"plr_ref":0.000001},"URLLC":{"delay_ref_ms":10,"plr_ref":0.000001}}
# Load thresholds from DB (docker-compose sets true for ms1): CONGESTION_THRESHOLDS_FROM_DB=true

# MS3 NOC dashboard — SESSION_SECRET must be >= 16 chars; if unset, SECRET_KEY is used (ms3/app.py). SECRET_KEY is also read in config.py.
SESSION_SECRET=change-me-long-random-string
# Optional: browser URL prefix when MS3 is not behind Nginx (Nginx sets X-Forwarded-Prefix /noc). Example: MS3_PUBLIC_PREFIX=/noc
# MS3_PUBLIC_PREFIX=
SECRET_KEY=change-this-secret-key-in-production
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# Email alerts (config.py → alert_service.AlertService)
ALERT_EMAIL=admin@company.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Service URLs (config.py defaults differ; use Docker hostnames inside compose)
MS1_URL=http://ms1:5000
MS2_URL=http://ms2:5000
MS5_URL=http://ms5:5000

# MS2 anomaly — Keras autoencoder (.h5) + Isolation Forest; volume ./ml:/app/ml in compose
# Resolution order: AUTOENCODER_PATH (if file exists), then ml/autoencoder_slice_{1|2|3}.h5, then ml/autoencoder.h5
AUTOENCODER_PATH=/app/ml/autoencoder.h5
SCALER_PATH=/app/ml/scaler.pkl
ENCODER_PATH=/app/ml/features.pkl
ISO_FOREST_PATH=/app/ml/iso_forest.pkl
# AUTOENCODER_THRESHOLD=0.000530
# ANOMALY_THRESHOLD=0.000530

# Slice selection models directory (slice_inference.py)
# ML_MODEL_DIR=ml

# CD / Docker Hub (docker-compose image names)
DOCKERHUB_USERNAME=jihedafli
IMAGE_TAG=latest

# MLflow (scripts/mlflow_integration.py, scripts/train_models.py)
# Host: UI often mapped to 5006 → container 5000
MLFLOW_TRACKING_URI=http://127.0.0.1:5006
# From a compose service on the same network: http://mlflow:5000
# MLFLOW_TRACKING_URI=sqlite:///ml/mlflow.db
MLFLOW_EXPERIMENT_NAME=5g-network-slice-selection
MLFLOW_REGISTER_MODELS=true
# MLFLOW_ARTIFACT_ROOT=file:///absolute/path/to/ml/mlartifacts
# Optional registry names: MLFLOW_REGISTRY_RF_MODEL, MLFLOW_REGISTRY_XGB_MODEL, etc. (see scripts/mlflow_integration.py)
# DISABLE_MLFLOW=true

TRAIN_DATA_PATH=./data/train_dataset.csv

# After training: scripts/push_metadata_to_elasticsearch.py (train_models.py)
# ELASTICSEARCH_URL=http://elasticsearch:9200
# ELASTICSEARCH_INDEX=network-slicing-metrics
# DISABLE_ELASTICSEARCH_PUSH=true

# Register models to MS-5 after train_models.py (scripts/train_models.py)
# DISABLE_MS5_REGISTER=true

# MS-5 model artifacts root (ms5_model_management/app.py)
# ML_ARTIFACTS_PATH=

# Process listen port (FastAPI services: app.py, ms3, anomaly, ms5)
# PORT=5000

# Integration tests (test_api.py)
# NGINX_URL=http://localhost
